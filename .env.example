COORDINATOR_HOST=0.0.0.0
COORDINATOR_PORT=8000
COORDINATOR_DB_PATH=/tmp/coordinator.db
WORKER_TOKEN=prototype-secret
HEARTBEAT_TIMEOUT_SECONDS=15
ASSIGNMENT_TIMEOUT_SECONDS=10
MAX_JOB_RETRIES=1
NGROK_AUTOSTART=1
# Set either NGROK_AUTHTOKEN or pre-authenticate ngrok on the machine.
NGROK_AUTHTOKEN=
# Optional explicit path if ngrok.exe is not beside the coordinator exe or on PATH.
NGROK_PATH=
# Optional fixed assigned ngrok dev domain, for example https://your-name.ngrok-free.app
NGROK_URL=
